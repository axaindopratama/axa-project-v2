{
  "name": "axa-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "dev:wifi": "next dev -H 0.0.0.0 -p 3000",
    "dev:wifi:3001": "next dev -H 0.0.0.0 -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "rbac:guard:metadata-role": "bash -lc \"if grep -RInE --include='*.ts' --include='*.tsx' 'user_metadata\\.role|app_metadata\\.role' src --exclude='rbac.ts'; then echo 'RBAC guard failed: direct metadata role read detected outside src/lib/rbac.ts'; exit 1; else echo 'RBAC guard passed: no direct metadata role read outside helper'; fi\"",
    "rbac:quality-gate": "node scripts/rbac-quality-gate.mjs",
    "rbac:ci": "npm run lint && npm run rbac:guard:metadata-role && npm run rbac:quality-gate"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.8.0",
    "next": "^16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
